# =============================================================================
# service-admin (admin-server, 8090) — TODO 템플릿
#
# ⚠️ PR #433(admin-server 모놀리식 분리)이 dev-msa에 머지되기 전까지는 비활성.
#    이 파일은 확장자가 .yaml.todo 라서 `kubectl apply -f k8s/` 에 잡히지 않는다.
#    #433 머지 후:
#      1) git fetch && git merge origin/dev-msa  (settings.gradle.kts에 :admin-server 추가됨)
#      2) qtai-server/admin-server/Dockerfile 작성(다른 서비스와 동일 패턴)
#      3) 이 파일을 34-service-admin.yaml 로 rename
#      4) docker-compose.yml 의 service-admin 주석 블록도 해제
#
# admin-server는 admin/audit/report관리 컨트롤러만 잔류한 모놀리식 복사본.
# 관리자 토큰의 members.role=ADMIN + admin_users.admin_role 이중검증을 수행한다(CLAUDE.md §5).
# 개인키는 주입하지 않고 공개키로 검증만 한다.
# =============================================================================
apiVersion: apps/v1
kind: Deployment
metadata:
  name: service-admin
  namespace: qtai
  labels:
    app: service-admin
spec:
  replicas: 1
  selector:
    matchLabels:
      app: service-admin
  template:
    metadata:
      labels:
        app: service-admin
    spec:
      containers:
        - name: service-admin
          image: qtai/admin-server:local
          imagePullPolicy: IfNotPresent
          ports:
            - containerPort: 8090
          envFrom:
            - configMapRef: { name: qtai-config }
          env:
            - name: DB_PASSWORD
              valueFrom: { secretKeyRef: { name: qtai-secret, key: DB_PASSWORD } }
            - name: SECURITY_JWT_PUBLIC_KEY
              valueFrom: { secretKeyRef: { name: qtai-secret, key: JWT_PUBLIC_KEY } }
          readinessProbe:
            tcpSocket: { port: 8090 }
            initialDelaySeconds: 30
            periodSeconds: 10
            failureThreshold: 12
          livenessProbe:
            tcpSocket: { port: 8090 }
            initialDelaySeconds: 60
            periodSeconds: 20
          resources:
            requests: { cpu: "150m", memory: "384Mi" }
            limits: { memory: "768Mi" }
---
apiVersion: v1
kind: Service
metadata:
  name: service-admin
  namespace: qtai
spec:
  type: NodePort
  selector:
    app: service-admin
  ports:
    - port: 8090
      targetPort: 8090
      nodePort: 30090       # http://localhost:30090
