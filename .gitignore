# .gitignore — QT-AI

# 환경변수 (절대 커밋 금지)
.env
*.env.local

# JWT 키
*.pem
keys/

# =============================================================================
# Gradle / Java
# =============================================================================
.gradle/
build/
out/
*.class
*.jar
!**/src/main/**/build/
!**/src/test/**/build/
.idea/
*.iml
*.iws
*.ipr

# =============================================================================
# Python
# =============================================================================
__pycache__/
*.py[cod]
*$py.class
.venv/
venv/
.Python
pip-log.txt
.pytest_cache/
*.egg-info/
dist/

# =============================================================================
# Flutter / Dart
# =============================================================================
.dart_tool/
.flutter-plugins
.flutter-plugins-dependencies
.packages
.pub-cache/
.pub/
build/
pubspec.lock

# =============================================================================
# 시스템
# =============================================================================
.DS_Store
Thumbs.db
*.log

# =============================================================================
# 테스트 커버리지
# =============================================================================
htmlcov/
.coverage
coverage.xml
*.lcov
