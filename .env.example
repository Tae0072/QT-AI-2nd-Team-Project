# QT-AI 로컬 환경변수 템플릿
# 복사후: cp .env.example .env → 실제 값 입력
# .env 파일은 .gitignore에 포함되어야 함 — 코드에 커밋 금지!
# 프로덕션 시크릿은 K8s Secret으로 관리

# =============================================================================
# 서비스 포트 (로컬 직접 실행 시)
# =============================================================================
GATEWAY_PORT=8080
BFF_PORT=8083
AUTH_SERVICE_PORT=8081
BIBLE_SERVICE_PORT=8082
AI_SERVICE_PORT=8085
JOURNAL_SERVICE_PORT=8084

# =============================================================================
# MySQL
# ⚠️ PostgreSQL 절대 사용 금지
# =============================================================================
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_DATABASE=qtai
MYSQL_USERNAME=qtai_user
MYSQL_PASSWORD=change_me_local
MYSQL_ROOT_PASSWORD=change_me_root

# =============================================================================
# Redis
# Redis-Cache (Bible Service 전용)
# Redis-WS    (Auth + BFF 세션/JWT blacklist 전용)
# =============================================================================
REDIS_CACHE_HOST=localhost
REDIS_CACHE_PORT=6379

REDIS_WS_HOST=localhost
REDIS_WS_PORT=6380

# =============================================================================
# Kafka KRaft
# ⚠️ ZooKeeper 절대 사용 금지
# =============================================================================
KAFKA_BOOTSTRAP_SERVERS=localhost:9092

# Apicurio Schema Registry
# ⚠️ 포트 8086 (로컬 기준) — Auth 8081과 충돌 방지
# ⚠️ Confluent Schema Registry 사용 금지 (라이선스)
SCHEMA_REGISTRY_URL=http://localhost:8086

# =============================================================================
# ChromaDB (AI Service 전용)
# =============================================================================
CHROMADB_HOST=localhost
CHROMADB_PORT=8000

# =============================================================================
# JWT / 인증
# RS256 키쌍 — 실제 키는 K8s Secret으로 관리
# 로컬에서만 여기에 경로 입력
# =============================================================================
JWT_ACCESS_TOKEN_TTL=1800
JWT_REFRESH_TOKEN_TTL=1209600
JWT_PRIVATE_KEY_PATH=./keys/private.pem
JWT_PUBLIC_KEY_PATH=./keys/public.pem

# =============================================================================
# Anthropic Claude API (AI Service 전용)
# ⚠️ 이 값은 컴바에 절대 커밋 금지!
# =============================================================================
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxx

# =============================================================================
# Google OAuth
# =============================================================================
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# =============================================================================
# 모니터링
# ⚠️ Tracing: Jaeger만 허용 (Tempo 금지)
# =============================================================================
JAEGER_ENDPOINT=http://localhost:4318/v1/traces
PROMETHEUS_PORT=9090
GRAFANA_PORT=3000
LOKI_ENDPOINT=http://localhost:3100

# =============================================================================
# Spring 프로파일 (Spring Boot 서비스 공통)
# =============================================================================
SPRING_PROFILES_ACTIVE=local
