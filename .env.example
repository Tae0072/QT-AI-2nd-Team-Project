# QT-AI 로컬/시연 실행용 환경변수 예시.
# 사용법: cp .env.example .env  후 아래 값을 채운다. 실제 .env는 커밋 금지(.gitignore 등록됨).
#
# JWT — RS256 키 (Base64, private=PKCS8 / public=X509).
# 환경마다 직접 생성한 키를 사용한다. 저장소에는 어떤 키도 커밋하지 않는다(테스트는 부팅 시 자동 생성).
# 키 생성(로컬/시연/운영 공통):
#   openssl genpkey -algorithm RSA -pkeyopt rsa_keygen_bits:2048 -outform DER -out private.der
#   openssl rsa -in private.der -inform DER -pubout -outform DER -out public.der
#   JWT_PRIVATE_KEY=$(base64 -w0 private.der)   # PKCS8
#   JWT_PUBLIC_KEY=$(base64 -w0 public.der)     # X509
# 운영(prod)은 생성 키를 안전한 시크릿 저장소(예: 환경변수/볼트)로 주입하고 주기적으로 회전한다.
JWT_PRIVATE_KEY=
JWT_PUBLIC_KEY=

# (선택) DeepSeek AI — 미설정 시 AI 외부호출 기능만 비활성, 기동에는 무방.
DEEPSEEK_API_KEY=
