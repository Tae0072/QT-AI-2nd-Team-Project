# QT-AI MSA 로컬 배포용 환경변수 예시.
# 사용법: cp .env.example .env  후 아래 값을 채운다. 실제 .env는 커밋 금지(.gitignore 등록됨).
# 가장 쉬운 방법: 키 생성 스크립트를 실행하면 .env가 자동 생성/갱신된다.
#   Windows:  ./scripts/generate-keys.ps1
#   Linux/Mac: ./scripts/generate-keys.sh
#
# 평문 키/비밀번호는 저장소에 커밋하지 않는다(테스트는 부팅 시 자동 생성 키 사용).

# -----------------------------------------------------------------------------
# DB (단일 MySQL 공유) — 로컬 기본값. 운영은 안전한 시크릿으로 주입.
# -----------------------------------------------------------------------------
MYSQL_DATABASE=qtai
DB_USERNAME=qtai
DB_PASSWORD=change-me-local
MYSQL_ROOT_PASSWORD=change-me-root-local
# JPA 스키마 전략: 로컬은 update(엔티티에서 테이블 생성). 운영 기본은 validate.
JPA_DDL_AUTO=update

# 호스트 포트(로컬 다른 MySQL/Redis와 충돌 방지용 매핑). 컨테이너 내부 포트는 고정.
MYSQL_HOST_PORT=3307
REDIS_HOST_PORT=6380

# 서비스 외부 노출 포트(기본값과 동일, 필요 시 변경)
USER_SERVICE_PORT=8081
BIBLE_SERVICE_PORT=8082
NOTE_SERVICE_PORT=8083
AI_SERVICE_PORT=8084

# -----------------------------------------------------------------------------
# JWT — RS256 키 (Base64, private=PKCS8 / public=X509).
# service-user가 개인키로 발급, 나머지 서비스는 공개키로 검증만 한다.
# 직접 생성하려면(스크립트가 동일 작업 수행):
#   openssl genpkey -algorithm RSA -pkeyopt rsa_keygen_bits:2048 -outform DER -out private.der
#   openssl rsa -in private.der -inform DER -pubout -outform DER -out public.der
#   JWT_PRIVATE_KEY=$(base64 -w0 private.der)   # PKCS8
#   JWT_PUBLIC_KEY=$(base64 -w0 public.der)     # X509
# 운영(prod)은 생성 키를 안전한 시크릿 저장소(환경변수/볼트)로 주입하고 주기적으로 회전한다.
# -----------------------------------------------------------------------------
JWT_PRIVATE_KEY=
JWT_PUBLIC_KEY=

# -----------------------------------------------------------------------------
# 선택 항목
# -----------------------------------------------------------------------------
# Kakao 사용자 정보 조회 URL (기본값 사용 가능)
KAKAO_USER_INFO_URL=https://kapi.kakao.com/v2/user/me
# 관리자 웹(별도 오리진) CORS 허용
CORS_ALLOWED_ORIGINS=http://localhost:3000
# DeepSeek AI — 미설정 시 AI 외부호출 기능만 비활성, 기동에는 무방.
DEEPSEEK_API_KEY=
# AI 사전 생성/검증 스케줄러 — 로컬 기동 안정성 위해 기본 false.
AI_SCHEDULING_ENABLED=false
