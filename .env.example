# QT-AI 로컬/시연 실행용 환경변수 예시.
# 사용법: cp .env.example .env  후 아래 값을 채운다. 실제 .env는 커밋 금지(.gitignore 등록됨).
#
# JWT — RS256 키 (Base64, private=PKCS8 / public=X509).
# 시연/로컬용으로는 테스트 전용 키를 그대로 쓸 수 있다:
#   qtai-server/src/test/resources/application.yml 의 security.jwt.private-key / public-key 값 복사.
# 운영(prod)에서는 절대 테스트 키를 쓰지 말고 별도 생성 키를 안전한 시크릿 저장소로 주입한다.
JWT_PRIVATE_KEY=
JWT_PUBLIC_KEY=

# (선택) DeepSeek AI — 미설정 시 AI 외부호출 기능만 비활성, 기동에는 무방.
DEEPSEEK_API_KEY=
