# 관리자 웹이 호출할 백엔드 API 기본 주소.
# - vite proxy(개발용)를 쓰면 그대로 '/api/v1' 로 둔다. (vite.config.ts의 proxy가 처리)
# - 배포 등으로 백엔드를 직접 호출하려면 전체 주소를 넣는다. 예) https://api.example.com/api/v1
VITE_API_BASE_URL=/api/v1

# [개발용] vite proxy 가 '/api' 요청을 전달할 백엔드 주소.
# - 기본(모놀리식 직접): http://localhost:8080
# - MSA 게이트웨이(service-gateway) 경유: http://localhost:8000
#   게이트웨이가 떠 있으면 이 한 줄만 8000 으로 바꾸면 된다. 코드 변경 없음.
#   (게이트웨이가 /api/v1/admin/** 를 같은 경로로 라우팅하므로 admin-web 은 영향 없음)
VITE_API_PROXY_TARGET=http://localhost:8080

# [DEV 전용] dev 서버(dev-bypass)에서 관리자로 인증할 회원 id (X-Dev-User-Id 로 전송).
# 백엔드 qtai.dev.admin-member-id 와 반드시 같아야 한다. 기본 1(dev 회원 시드 관례).
# prod 빌드(IS_DEV=false)에서는 전송되지 않는다.
VITE_DEV_ADMIN_MEMBER_ID=1

# 실제 값은 .env 파일에 넣고, .env 는 git에 올리지 않는다. (.gitignore 처리됨)
