# 관리자 웹이 호출할 백엔드 API 기본 주소.
# - vite proxy(개발용)를 쓰면 그대로 '/api/v1' 로 둔다. (vite.config.ts의 proxy가 처리)
# - 배포 등으로 백엔드를 직접 호출하려면 전체 주소를 넣는다. 예) https://api.example.com/api/v1
VITE_API_BASE_URL=/api/v1

# [개발용] vite proxy 가 '/api' 요청을 전달할 백엔드 주소.
# - 2026-06-10 결정 ③: admin-web 은 처음부터 admin-server(8090) 기준.
# - 기본: http://localhost:8090 (admin-server)
#   게이트웨이 경유 시 게이트웨이 주소로 바꾼다(이 한 줄만, 코드 변경 없음).
#   (/api/v1/admin/** 를 같은 경로로 라우팅하면 admin-web 은 영향 없음)
VITE_API_PROXY_TARGET=http://localhost:8090

# 카카오 JavaScript SDK 키 (로그인 버튼용). 루트 .env 의 KAKAO_JS_KEY 값을 넣는다.
VITE_KAKAO_JS_KEY=your_kakao_js_key

# 실제 값은 .env 파일에 넣고, .env 는 git에 올리지 않는다. (.gitignore 처리됨)
